{
  "manifest_version": 3,
  "name": "Twitch Controller",
  "version": "1.1",
  "description": "Control Twitch tabs: mute, pause, and switch between streams",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["*://*.twitch.tv/*"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-twitch-mute": {
      "description": "Toggle mute on Twitch tabs"
    },
    "toggle-twitch-pause": {
      "description": "Toggle pause/resume on Twitch tabs"
    },
    "next-twitch-tab": {
      "description": "Switch to next Twitch tab"
    }
  }
}
